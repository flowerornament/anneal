# Source-backed topic documentation for standard diagnostics.

@doc(
  name: "checks",
  doc: "Diagnostic standard-library rules. E001 is available for convergence entropy; the full v1.x diagnostic catalog is specified by CR-D23."
).

@doc(
  name: "diagnostic",
  doc: "Bind standard diagnostic rows as code, severity, handle, file, line, and evidence."
).
diagnostic("E001", "error", src, file, line, target) :=
  *edge{from: src, to: target, file: file, line: line},
  not *handle{id: target}.
